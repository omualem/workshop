{
  "name": "rental-marketplace-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "setup:local": "node scripts/setup-local.mjs && npm run db:migrate && npm run db:seed",
    "db:generate": "npm run prisma:generate -w apps/api",
    "db:migrate": "npm run prisma:migrate -w apps/api",
    "db:seed": "npm run prisma:seed -w apps/api",
    "db:reset": "node scripts/reset-local-db.mjs && npm run setup:local",
    "dev:web": "npm run dev -w apps/web",
    "dev:api": "npm run start:dev -w apps/api",
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "build": "npm run build -ws --if-present",
    "lint": "npm run lint -ws --if-present",
    "test": "npm run test -ws --if-present",
    "prisma:generate": "npm run prisma:generate -w apps/api",
    "prisma:migrate": "npm run prisma:migrate -w apps/api",
    "prisma:seed": "npm run prisma:seed -w apps/api"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "concurrently": "^9.1.2",
    "prettier": "^3.5.3",
    "typescript": "^5.9.3"
  }
}
